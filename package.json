{
  "name": "stackdock",
  "private": true,
  "version": "0.1.0",
  "main": "dist-electron/electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "npm run build && electron . --trace-warnings --agent-browser --built",
    "build": "node scripts/build-if-needed.cjs",
    "build:force": "tsc -p electron/tsconfig.json && vite build",
    "build:app": "npm run clean:dist && npm run build && electron-builder --win portable --x64 -c.compression=maximum",
    "build:installer": "npm run clean:dist && npm run build && electron-builder --win nsis --x64 -c.compression=maximum",
    "build:web-installer": "npm run clean:dist && npm run build && electron-builder --win nsis-web --x64 -c.compression=maximum",
    "start": "electron .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  },
  "build": {
    "directories": {
      "output": "release"
    },
    "appId": "com.stackdock.app",
    "productName": "StackDock",
    "compression": "maximum",
    "electronLanguages": [
      "en-US"
    ],
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "node_modules/node-pty/prebuilds/win32-x64/**/*.{node,dll,exe}"
    ],
    "files": [
      "dist/**/*",
      "!dist/win-unpacked{,/**}",
      "!dist/win-unpacked.tmp{,/**}",
      "!dist/*.exe",
      "!dist/builder-effective-config.yaml",
      "!node_modules/node-pty/prebuilds/win32-arm64{,/**}",
      "!node_modules/node-pty/prebuilds/**/*.pdb",
      "!node_modules/node-pty/deps{,/**}",
      "!node_modules/node-pty/third_party{,/**}",
      "!node_modules/node-pty/src{,/**}",
      "!node_modules/node-pty/build{,/**}",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  },
  "devDependencies": {
    "@fontsource-variable/fira-code": "^5.2.7",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/barlow": "^5.2.8",
    "@fontsource/fira-mono": "^5.2.7",
    "@fontsource/google-sans-flex": "^5.2.4",
    "@fontsource/monaspace-neon": "^5.2.5",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/source-code-pro": "^5.2.7",
    "@mdi/js": "^7.4.47",
    "@types/node": "^22.15.29",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "concurrently": "^9.2.0",
    "electron": "^36.5.0",
    "electron-builder": "^26.0.12",
    "monaco-editor": "^0.52.0",
    "nodemon": "^3.1.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.3",
    "zustand": "^5.0.6"
  }
}
